# ============================================================================
# Enterprise Deal Commander — frontend (Vite) environment
# ============================================================================
# Copy this file to `.env` in the same directory. `.env` is git-ignored.

# Port the Vite dev server / preview server listens on (required by the dev script).
PORT=5173

# Base path the SPA is served under. Use "/" for local development.
# When the SPA is bundled into the API server for single-origin hosting this
# is set to the sub-path the app is mounted at.
BASE_PATH=/

# Target the dev server proxies `/api` requests to.
# Defaults to http://localhost:5000 (the local API server) if unset.
API_PROXY_TARGET=http://localhost:5000
