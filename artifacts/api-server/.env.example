# ============================================================================
# Enterprise Deal Commander — API server environment
# ============================================================================
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is git-ignored and must never be committed.

# PostgreSQL connection string (required).
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# The app uses the `edc` and `edc_v2` schemas inside this database.
DATABASE_URL=postgres://edc:edc@localhost:5432/edc

# Secret used to sign session JWTs (required in production).
# Generate a long random value, e.g.:  openssl rand -hex 32
# In development a fallback constant is used if this is unset, but you should
# always set it explicitly.
SESSION_SECRET=change-me-to-a-long-random-string

# Node environment: "development" | "production".
# In production, session cookies are marked Secure and SESSION_SECRET is required.
NODE_ENV=development

# Port the API server listens on (defaults to 5000 if unset).
PORT=5000
